---
// Navbar — always-readable dark gradient top, glassmorphism on scroll
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 navbar-default">
  <!-- Persistent dark gradient for readability over any image -->
  <div class="navbar-bg absolute inset-0 z-0"></div>

  <div class="container-wide relative z-10 flex items-center justify-between py-4 px-4">

    <!-- Logo + brand name -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Beach Portraits Maui Home">
      <img
        src="/images/logo-200-light.png"
        alt="Grins2Go Beach Portraits Maui"
        class="h-14 w-auto transition-transform duration-300 group-hover:scale-105 nav-logo-shadow"
        id="nav-logo"
      />
      <div class="hidden sm:flex flex-col">
        <span class="font-serif text-white text-sm tracking-wide leading-tight nav-text-shadow" style="font-size: 0.85rem;">Beach Portraits Maui</span>
        <span class="text-white/50 font-sans uppercase tracking-[0.2em] nav-text-shadow" style="font-size: 0.5rem;">Since 2006</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {[
        ['/', 'Home'],
        ['/gallery', 'Gallery'],
        ['/pricing', 'Pricing'],
        ['/reviews', 'Reviews'],
        ['/about', 'About'],
      ].map(([href, label]) => (
        <a
          href={href}
          class="nav-link text-white/85 hover:text-white font-sans font-medium uppercase tracking-[0.18em] transition-colors duration-200 nav-text-shadow"
          style="font-size: 0.7rem;"
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Phone CTA -->
    <a
      href="tel:+18082421424"
      id="nav-phone"
      class="hidden md:flex items-center gap-2 btn-gold"
      style="padding: 0.55rem 1.2rem;"
    >
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      <span>(808) 242-1424</span>
    </a>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2 cursor-pointer" aria-label="Open navigation menu" aria-expanded="false">
      <span class="hamburger-line block h-px w-6 bg-white transition-all duration-300"></span>
      <span class="hamburger-line block h-px w-6 bg-white transition-all duration-300"></span>
      <span class="hamburger-line block h-px w-4 bg-white transition-all duration-300 self-end"></span>
    </button>
  </div>

  <!-- Tagline bar — visible below nav on hero pages -->
  <div id="navbar-tagline" class="relative z-10 text-center py-1.5 transition-all duration-500">
    <p class="font-sans uppercase tracking-[0.3em] text-white/60 nav-text-shadow" style="font-size: 0.55rem; letter-spacing: 0.35em;">
      Maui's Premier Beach Portrait Photographers
    </p>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 flex-col items-center justify-center bg-charcoal-950 hidden" aria-hidden="true">
  <button id="mobile-close-btn" class="absolute top-5 right-6 text-white/60 hover:text-white transition-colors cursor-pointer" aria-label="Close menu">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
  <nav class="flex flex-col items-center gap-8 text-center">
    {[['/', 'Home'], ['/gallery', 'Gallery'], ['/pricing', 'Pricing'], ['/reviews', 'Reviews'], ['/about', 'About']].map(([href, label]) => (
      <a href={href} class="mobile-nav-link font-serif text-3xl text-white/80 hover:text-gold-400 transition-colors duration-200">{label}</a>
    ))}
    <a href="tel:+18082421424" class="btn-gold mt-4">Call (808) 242-1424</a>
  </nav>
</div>

<style>
  /* Default state — dark gradient so nav is readable over ANY image */
  .navbar-bg {
    background: linear-gradient(to bottom,
      hsl(210 30% 6% / 0.85) 0%,
      hsl(210 30% 6% / 0.65) 50%,
      hsl(210 30% 6% / 0.25) 80%,
      transparent 100%
    );
    transition: all 0.5s ease;
  }

  /* Scrolled state — solid glass bar */
  #navbar.scrolled .navbar-bg {
    background: hsl(210 25% 10% / 0.95);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid hsl(40 30% 97% / 0.06);
  }
  #navbar.scrolled { box-shadow: 0 2px 20px hsl(210 30% 6% / 0.3); }
  #navbar.scrolled #nav-logo { height: 2.5rem; }
  #navbar.scrolled #navbar-tagline { display: none; }

  /* Text shadow ensures readability even on bright sky areas */
  .nav-text-shadow {
    text-shadow:
      0 1px 8px hsl(210 30% 6% / 0.8),
      0 1px 3px hsl(210 30% 6% / 0.6);
  }
  .nav-logo-shadow {
    filter: drop-shadow(0 1px 6px hsl(210 30% 6% / 0.7));
  }

  #mobile-menu.open { display: flex; }
  .nav-link { position: relative; }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-gold-500);
    transition: width 0.3s ease;
  }
  .nav-link:hover::after { width: 100%; }
</style>

<script>
  const navbar = document.getElementById('navbar')!;
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const closeBtn = document.getElementById('mobile-close-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  menuBtn.addEventListener('click', () => {
    mobileMenu.classList.add('open');
    mobileMenu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  });
  const closeMenu = () => {
    mobileMenu.classList.remove('open');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };
  closeBtn.addEventListener('click', closeMenu);
  mobileMenu.querySelectorAll('.mobile-nav-link').forEach(link => link.addEventListener('click', closeMenu));
</script>
