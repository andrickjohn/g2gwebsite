---
interface Props {
  reviews: Array<{
    title: string;
    text: string;
    author: string;
    rating: number;
  }>;
  featured?: boolean;
}

const { reviews, featured = false } = Astro.props;
const displayReviews = featured ? reviews.slice(0, 12) : reviews;

function stars(n: number) {
  return '★'.repeat(Math.max(0, Math.min(5, n)));
}
---

{featured ? (
  <!-- Featured carousel mode -->
  <div class="reviews-carousel relative overflow-hidden" id="reviews-carousel">
    <div class="carousel-track flex transition-transform duration-700 ease-in-out" id="carousel-track">
      {displayReviews.map((review) => (
        <div class="carousel-slide flex-none w-full md:w-1/3 px-3">
          <div class="h-full flex flex-col gap-4 bg-white border border-charcoal-900/8 p-8 relative hover:border-gold-500/30 hover:shadow-lg transition-all duration-300" style="border-left: 3px solid var(--color-gold-500);">
            <span class="absolute top-3 right-5 font-serif text-6xl text-gold-500/25 leading-none select-none">&ldquo;</span>
            <div class="stars text-base" style="color: var(--color-gold-500);">{stars(review.rating)}</div>
            <p class="font-serif text-xl text-charcoal-900 leading-snug">&ldquo;{review.title}&rdquo;</p>
            <p class="text-sm text-charcoal-600/70 leading-relaxed flex-1">{review.text}</p>
            <div class="flex items-center gap-3 pt-3 border-t border-charcoal-900/6">
              <div class="w-8 h-8 rounded-full bg-gold-500/15 flex items-center justify-center flex-none">
                <span class="font-serif text-sm text-charcoal-800">{review.author.charAt(0)}</span>
              </div>
              <span class="text-sm font-medium text-charcoal-900">{review.author}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="flex justify-center items-center gap-4 mt-8">
      <button id="carousel-prev" class="text-charcoal-500 hover:text-charcoal-900 transition-colors cursor-pointer" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="flex gap-2" id="carousel-dots"></div>
      <button id="carousel-next" class="text-charcoal-500 hover:text-charcoal-900 transition-colors cursor-pointer" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>
) : (
  <!-- Full reviews grid -->
  <div class="reviews-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    {displayReviews.map((review) => (
      <article class="reveal flex flex-col gap-4 bg-white border border-charcoal-900/8 p-6 relative hover:border-gold-500/30 hover:shadow-lg transition-all duration-300">
        <span class="absolute top-3 right-4 font-serif text-4xl text-gold-500/12 leading-none select-none">&ldquo;</span>
        <div class="stars text-sm">{stars(review.rating)}</div>
        <p class="font-serif text-base text-charcoal-900 leading-snug">&ldquo;{review.title}&rdquo;</p>
        <p class="text-caption text-charcoal-600/60 leading-relaxed flex-1">{review.text}</p>
        <div class="flex items-center gap-3 pt-2 border-t border-charcoal-900/6">
          <div class="w-6 h-6 rounded-full bg-charcoal-900/8 flex items-center justify-center flex-none">
            <span class="font-serif text-xs text-charcoal-700">{review.author.charAt(0)}</span>
          </div>
          <span class="text-caption font-medium text-charcoal-900">{review.author}</span>
        </div>
      </article>
    ))}
  </div>
)}

<script>
  const track  = document.getElementById('carousel-track');
  const dotsEl = document.getElementById('carousel-dots');
  if (track && dotsEl) {
    const slides = track.querySelectorAll('.carousel-slide');
    const perView = () => window.innerWidth >= 768 ? 3 : 1;
    const total = Math.ceil(slides.length / perView());
    let current = 0;

    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.className = `w-1.5 h-1.5 rounded-full transition-all duration-300 cursor-pointer ${i === 0 ? 'bg-gold-500 w-4' : 'bg-charcoal-900/20'}`;
      dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
      dot.addEventListener('click', () => goTo(i));
      dotsEl.appendChild(dot);
    }

    function goTo(idx) {
      current = ((idx % total) + total) % total;
      const pv = perView();
      const pct = (100 / pv) * current;
      track.style.transform = `translateX(-${pct}%)`;
      dotsEl.querySelectorAll('button').forEach((d, i) => {
        d.className = `rounded-full transition-all duration-300 cursor-pointer ${i === current ? 'bg-gold-500 w-4 h-1.5' : 'bg-charcoal-900/20 w-1.5 h-1.5'}`;
      });
    }

    document.getElementById('carousel-prev')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('carousel-next')?.addEventListener('click', () => goTo(current + 1));

    let timer = setInterval(() => goTo(current + 1), 5500);
    track.addEventListener('mouseenter', () => clearInterval(timer));
    track.addEventListener('mouseleave', () => { timer = setInterval(() => goTo(current + 1), 5500); });
  }
</script>
