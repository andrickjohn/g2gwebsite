---
import Layout from '../layouts/Layout.astro';

// Grins2Go Landing Page
---

<Layout>
	<main>
		<!-- Hero Section -->
		<section class="hero section-padding">
			<div class="container">
				<div class="hero-content" data-reveal="visible">
					<span class="text-gold italic serif">Maui Portrait Photography</span>
					<h1>Family Memories That <br /><span class="italic">Last a Lifetime</span></h1>
					<p>Capturing the warmth of the sun and the joy of your family in the most beautiful beaches of Maui.</p>
					<div class="hero-actions">
						<a href="#gallery" class="btn btn-primary">View Galleries</a>
						<a href="#booking" class="btn btn-secondary">Book a Session</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Trust / Stats Bar -->
		<section class="stats">
			<div class="container grid-stats">
				<div class="stat-item">
					<span class="stat-number">15+</span>
					<span class="stat-label">Years in Maui</span>
				</div>
				<div class="stat-item">
					<span class="stat-number">2k+</span>
					<span class="stat-label">Happy Families</span>
				</div>
				<div class="stat-item">
					<span class="stat-number">5.0</span>
					<span class="stat-label">Rating</span>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero {
		min-height: 80vh;
		display: flex;
		align-items: center;
		background: linear-gradient(rgba(13, 47, 47, 0.2), rgba(13, 47, 47, 0.2)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&q=80&w=2073') center/cover no-repeat;
		color: white;
	}

	.hero-content h1 {
		font-size: clamp(2.5rem, 8vw, 4.5rem);
		color: white;
		margin-block: var(--space-s);
	}

	.hero-content p {
		max-width: 50ch;
		font-size: var(--space-s);
		margin-bottom: var(--space-m);
	}

	.hero-actions {
		display: flex;
		gap: var(--space-s);
	}

	.btn {
		padding: var(--space-s) var(--space-m);
		border-radius: var(--radius-m);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.8rem;
	}

	.btn-primary {
		background: var(--accent);
		color: var(--color-teal-900);
	}

	.btn-secondary {
		border: 1px solid white;
		color: white;
		backdrop-filter: blur(10px);
	}

	.grid-stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: var(--space-l);
		padding-block: var(--space-l);
		text-align: center;
		border-bottom: 1px solid hsla(var(--color-teal-900), 0.1);
	}

	.stat-number {
		display: block;
		font-family: var(--font-serif);
		font-size: 3rem;
		color: var(--accent);
	}

	.stat-label {
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.7rem;
		color: var(--text-muted);
	}
</style>
