---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Reviews from '../components/Reviews.astro';
import reviewsData from '../data/reviews.json';

const total = reviewsData.length;
---

<Layout
  title={`${total} Reviews | Beach Portraits Maui`}
  description={`Read all ${total} five-star reviews for Grins2Go Beach Portraits Maui. Real families share their experience with Maui's most trusted beach portrait photographers.`}
>
  <Navbar />

  <section class="relative pt-36 pb-20 bg-charcoal-950 text-white text-center">
    <div class="absolute inset-0 opacity-10">
      <img src="/uploads/2017/09/Maui-Beach-Family-Portrait-005-06-L.jpg" alt="" class="w-full h-full object-cover" loading="eager" aria-hidden="true" />
    </div>
    <div class="relative z-10 container-custom">
      <p class="text-eyebrow mb-4">Verified Reviews</p>
      <h1 class="text-headline text-white mb-4">{total} Five-Star Families</h1>
      <span class="accent-line-center mb-6"></span>
      <div class="stars text-2xl mb-3">★★★★★</div>
      <p class="text-body text-white/50">5.0 average across TripAdvisor, Yelp & Google</p>
    </div>
  </section>

  <section class="section-pad bg-ivory-50">
    <div class="container-custom">
      <Reviews reviews={reviewsData} featured={false} />
    </div>
  </section>

  <section class="bg-charcoal-900 text-white section-pad-sm">
    <div class="container-custom text-center flex flex-col items-center gap-5 reveal">
      <h2 class="text-title text-white">Add Your Family to the Story</h2>
      <p class="text-body text-white/50 max-w-[38ch]">Join hundreds of families who say this was the best thing they did on their Maui trip.</p>
      <a href="tel:+18082421424" class="btn-gold">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call (808) 242-1424
      </a>
    </div>
  </section>

  <Footer />
</Layout>
